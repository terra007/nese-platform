# ─────────────────────────────────────────────────────────────
#  NESE Platform — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Supabase — find these in your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Admin access — server-only, never use NEXT_PUBLIC_ prefix.
# ADMIN_EMAIL: the email used to log in at /admin/login
# ADMIN_USER_ID: the UUID of that user (Supabase Dashboard → Auth → Users)
# Both must be set; the UUID is verified on every authenticated request.
ADMIN_EMAIL=your-admin@email.com
ADMIN_USER_ID=your-supabase-user-uuid-here
